# AI API設定
# デフォルトはGemini（コスパ重視）
AI_PROVIDER=gemini  # gemini または claude

# Gemini API設定（デフォルト）
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-002  # gemini-2.5-flash-002 または gemini-2.0-flash-thinking-exp-01-21

# Claude API設定（オプション・高品質）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ファイル監視設定
WATCH_INTERVAL=60  # 秒単位
AUTO_UPDATE=true

# パス設定（通常は変更不要）
RAW_LOGS_DIR=../../.limitless/raw-logs
PHILOSOPHY_EXTRACT_DIR=../../.limitless/philosophy-extract
CLAUDE_MD_PATH=../../CLAUDE.md
